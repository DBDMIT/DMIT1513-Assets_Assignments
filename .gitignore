*.pdb.meta
*.mdb.meta

# Unity crash + build outputs
*/sysinfo.txt
*.apk
*.aab
*.unitypackage
*.unitypackage.meta
*.app
*.exe
*.dll
*.so
*.dylib

# Crashlytics
*/crashlytics-build.properties

# Addressables
*/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*

# Android auto-generated streaming assets
*/[Aa]ssets/[Ss]treamingAssets/aa.meta
*/[Aa]ssets/[Ss]treamingAssets/aa/*

# Unity Package Manager cache
*/[Pp]ackages/com.unity.package-manager*

# Ensure asset metadata is kept
!*/[Aa]ssets/**/*.meta
