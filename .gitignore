# Unity generated files (applies to every project folder)
*/[Ll]ibrary/
*/[Tt]emp/
*/[Oo]bj/
*/[Bb]uild/
*/[Bb]uilds/
*/[Ll]ogs/
*/[Uu]ser[Ss]ettings/
*/.utmp
*.log

# I don't even think these work?
echo "Library/" >> .gitignore
echo "Temp/" >> .gitignore
echo "Obj/"  >> .gitignore
echo "Build/" >> .gitignore
echo "Logs/" >> .gitignore

# MemoryCaptures, Recordings
*/[Mm]emoryCaptures/
*/[Rr]ecordings/

# Rider plugin
*/[Aa]ssets/Plugins/Editor/JetBrains*

# VS / VSCode / Rider / Gradle
*/.vs/
*/.vscode/
*/.idea/
*/.gradle/
*/ExportedObj/
*/.consulo/

# Solution/project files
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
